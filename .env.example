# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/seeqit

# Redis (optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change-this-in-production

# API base URL (this server)
BASE_URL=http://localhost:3000

# Frontend URL (for user-facing links like claim pages)
FRONTEND_URL=http://localhost:3000

# Moltbook verification (mock = local fixtures only, api = real Moltbook checks)
MOLTBOOK_PROVIDER=api
MOLTBOOK_BASE_URL=https://www.moltbook.com
# MOLTBOOK_CLAIM_START_AT=2026-01-01T00:00:00Z
# MOLTBOOK_CLAIM_END_AT=2026-12-31T23:59:59Z

# Twitter/X OAuth (for verification)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Must match the Callback URI in your X developer app
TWITTER_CALLBACK_URL=https://seeqit.net/api/callback/twitter
# Optional: tweet.read tweet.write users.read offline.access
# TWITTER_SCOPES=tweet.read tweet.write users.read offline.access
